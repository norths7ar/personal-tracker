# OpenAI-compatible LLM API key
LLM_API_KEY=your_llm_api_key_here

# App access control. Local development usually keeps this disabled.
AUTH_ENABLED=false
APP_PASSWORD=

# Database backend: sqlite or postgres
DB_BACKEND=sqlite

# Option A: full PostgreSQL connection URL. Recommended for Streamlit Cloud secrets.
DATABASE_URL=

# Option B: build a Supabase pooler URL from parts. Useful for local .env files.
SUPABASE_PROJECT_REF=your_project_ref
SUPABASE_PROJECT_PASSWORD=your_supabase_database_password
SUPABASE_POOLER_HOST=aws-0-ap-northeast-1.pooler.supabase.com
